{
  "manifest_version": 3,
  "name": "NoSite Leads Helper",
  "version": "1.0.0",
  "description": "Find small businesses on Google Maps that have no website and save them as leads. Manual, local-only, no backend.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NoSite Leads Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
